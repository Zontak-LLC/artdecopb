y1=\"500\" x2=\"887\" y2=\"60\"></line><line x1=\"500\" y1=\"500\" x2=\"960\" y2=\"124\"></line><line x1=\"500\" y1=\"500\" x2=\"1020\" y2=\"204\"></line><line x1=\"500\" y1=\"500\" x2=\"1064\" y2=\"296\"></line><line x1=\"500\" y1=\"500\" x2=\"1091\" y2=\"396\"></line><circle cx=\"500\" cy=\"500\" r=\"200\"></circle><circle cx=\"500\" cy=\"500\" r=\"300\" stroke-width=\"0.3\"></circle><circle cx=\"500\" cy=\"500\" r=\"400\" stroke-width=\"0.2\"></circle></g></svg></div><div class=\"relative z-10 max-w-5xl mx-auto px-4 pt-24 text-center\"><div class=\"mb-8\" style=\"opacity:0;transform:scale(0.8)\"><img alt=\"Art Deco Society of the Palm Beaches Logo\" width=\"160\" height=\"160\" decoding=\"async\" data-nimg=\"1\" class=\"mx-auto rounded-full border-2 border-gold/30 shadow-lg\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Flogo-adspb.jpg&amp;w=256&amp;q=75 1x, /_next/image?url=%2Fimages%2Flogo-adspb.jpg&amp;w=384&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Flogo-adspb.jpg&amp;w=384&amp;q=75\"/></div><p class=\"font-display text-gold tracking-[0.3em] uppercase text-sm sm:text-base mb-4\" style=\"opacity:0;transform:translateY(20px)\">Celebrating 39 Years · 1987–2026</p><h1 class=\"font-display text-cream text-4xl sm:text-6xl lg:text-7xl tracking-wide leading-tight\" style=\"opacity:0;transform:translateY(30px)\">Art Deco Society<br/><span class=\"text-gold\">of the Palm Beaches</span></h1><p class=\"mt-8 text-cream/60 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed\" style=\"opacity:0;transform:translateY(20px)\">Promoting education, preservation and awareness of Twentieth Century Art, Architecture &amp; Design in the Palm Beaches.</p><div class=\"mt-12 flex flex-col sm:flex-row items-center justify-center gap-4\" style=\"opacity:0;transform:translateY(20px)\"><a class=\"group bg-gold text-charcoal px-8 py-4 rounded-full font-display tracking-wider uppercase text-sm hover:bg-cream transition-colors flex items-center gap-2\" href=\"/events\">Upcoming Events<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right group-hover:translate-x-1 transition-transform\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a><a class=\"group border border-gold/50 text-gold px-8 py-4 rounded-full font-display tracking-wider uppercase text-sm hover:bg-gold/10 transition-colors\" href=\"/membership\">Become a Member</a></div><div class=\"mt-20 flex items-center justify-center\" style=\"opacity:0\"><div class=\"flex flex-col items-center gap-2\"><div class=\"w-px h-12 bg-gradient-to-b from-gold/50 to-transparent\"></div><p class=\"text-gold/40 text-xs tracking-[0.2em] uppercase\">A 501(c)3 Historic Preservation Organization</p></div></div></div></section></div><section class=\"py-24 px-4 sm:px-6 lg:px-8 bg-cream\"><div class=\"max-w-7xl mx-auto\"><div class=\"text-center mb-16\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex items-center justify-center gap-4 mb-6\"><div class=\"h-px w-16 bg-gold/30\"></div><div class=\"w-3 h-3 rotate-45 border border-gold/40\"></div><div class=\"h-px w-16 bg-gold/30\"></div></div><h2 class=\"font-display text-3xl sm:text-4xl lg:text-5xl tracking-wide text-charcoal\">Preserving Our Heritage</h2><p class=\"mt-4 text-lg max-w-2xl mx-auto text-charcoal/60\">For nearly four decades, we have been the leading voice for Art Deco preservation in South Florida.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\"><div class=\"text-center p-8 rounded-2xl bg-white shadow-sm hover:shadow-lg transition-shadow group\"><div class=\"w-16 h-16 mx-auto mb-6 rounded-2xl bg-gold/10 flex items-center justify-center group-hover:bg-gold/20 transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-building2 lucide-building-2 text-gold\" aria-hidden=\"true\"><path d=\"M10 12h4\"></path><path d=\"M10 8h4\"></path><path d=\"M14 21v-3a2 2 0 0 0-4 0v3\"></path><path d=\"M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2\"></path><path d=\"M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16\"></path></svg></div><h3 class=\"font-display text-lg text-charcoal mb-3\">Architecture</h3><p class=\"text-charcoal/60 text-sm leading-relaxed\">Documenting and protecting Art Deco buildings throughout the Palm Beaches.</p></div><div class=\"text-center p-8 rounded-2xl bg-white shadow-sm hover:shadow-lg transition-shadow group\"><div class=\"w-16 h-16 mx-auto mb-6 rounded-2xl bg-gold/10 flex items-center justify-center group-hover:bg-gold/20 transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-book-open text-gold\" aria-hidden=\"true\"><path d=\"M12 7v14\"></path><path d=\"M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z\"></path></svg></div><h3 class=\"font-display text-lg text-charcoal mb-3\">Education</h3><p class=\"text-charcoal/60 text-sm leading-relaxed\">Free lectures, walking tours, and publications sharing our architectural heritage.</p></div><div class=\"text-center p-8 rounded-2xl bg-white shadow-sm hover:shadow-lg transition-shadow group\"><div class=\"w-16 h-16 mx-auto mb-6 rounded-2xl bg-gold/10 flex items-center justify-center group-hover:bg-gold/20 transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users text-gold\" aria-hidden=\"true\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><path d=\"M16 3.128a4 4 0 0 1 0 7.744\"></path><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle></svg></div><h3 class=\"font-display text-lg text-charcoal mb-3\">Community</h3><p class=\"text-charcoal/60 text-sm leading-relaxed\">Events, exhibitions, and programs bringing people together through art and design.</p></div><div class=\"text-center p-8 rounded-2xl bg-white shadow-sm hover:shadow-lg transition-shadow group\"><div class=\"w-16 h-16 mx-auto mb-6 rounded-2xl bg-gold/10 flex items-center justify-center group-hover:bg-gold/20 transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-award text-gold\" aria-hidden=\"true\"><path d=\"m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526\"></path><circle cx=\"12\" cy=\"8\" r=\"6\"></circle></svg></div><h3 class=\"font-display text-lg text-charcoal mb-3\">Preservation</h3><p class=\"text-charcoal/60 text-sm leading-relaxed\">Advocating for the protection of our historic twentieth century landmarks.</p></div></div></div></section><section class=\"py-24 px-4 sm:px-6 lg:px-8 bg-ivory\"><div class=\"max-w-7xl mx-auto\"><div class=\"text-center mb-16\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex items-center justify-center gap-4 mb-6\"><div class=\"h-px w-16 bg-gold/30\"></div><div class=\"w-3 h-3 rotate-45 border border-gold/40\"></div><div class=\"h-px w-16 bg-gold/30\"></div></div><h2 class=\"font-display text-3xl sm:text-4xl lg:text-5xl tracking-wide text-charcoal\">Upcoming Events</h2><p class=\"mt-4 text-lg max-w-2xl mx-auto text-charcoal/60\">Join us for lectures, tours, and celebrations of Art Deco culture.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\"><div class=\"group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 ring-2 ring-gold/50\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"absolute top-4 right-4 z-10 bg-gold text-charcoal text-xs font-bold px-3 py-1 rounded-full tracking-wider uppercase\">Featured</div><div class=\"absolute top-4 left-4 z-10 bg-charcoal text-cream rounded-xl p-3 text-center min-w-[60px] shadow-lg\"><p class=\"text-gold text-xs font-bold uppercase tracking-wider\">Apr</p><p class=\"text-2xl font-display\">15</p></div><div class=\"h-2 bg-gradient-to-r from-gold via-copper to-gold\"></div><div class=\"p-6 pt-20\"><h3 class=\"font-display text-xl text-charcoal group-hover:text-gold transition-colors mb-3\">Art Deco Afternoons — Free Lecture Series</h3><p class=\"text-charcoal/60 text-sm leading-relaxed mb-4\">Join us for our popular free lecture series exploring Art Deco architecture, design, and history in the Palm Beaches. Expert speakers share fascinating stories of our architectural heritage.</p><div class=\"space-y-2 text-sm text-charcoal/50\"><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock text-gold\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6l4 2\"></path></svg><span>2:00 PM</span></div><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin text-gold\" aria-hidden=\"true\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg><span>Cultural Council of Palm Beach County, 601 Lake Avenue, Lake Worth Beach, FL</span></div></div><a href=\"mailto:Art@ArtDecoPB.org?subject=RSVP: Art Deco Afternoons — Free Lecture Series\" class=\"mt-6 inline-flex items-center gap-2 bg-charcoal text-cream px-6 py-2.5 rounded-full text-sm font-medium hover:bg-gold hover:text-charcoal transition-all duration-300 group-hover:translate-x-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calendar\" aria-hidden=\"true\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\"></rect><path d=\"M3 10h18\"></path></svg>RSVP Now</a></div></div><div class=\"group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 \" style=\"opacity:0;transform:translateY(30px)\"><div class=\"absolute top-4 left-4 z-10 bg-charcoal text-cream rounded-xl p-3 text-center min-w-[60px] shadow-lg\"><p class=\"text-gold text-xs font-bold uppercase tracking-wider\">Mar</p><p class=\"text-2xl font-display\">22</p></div><div class=\"h-2 bg-gradient-to-r from-gold via-copper to-gold\"></div><div class=\"p-6 pt-20\"><h3 class=\"font-display text-xl text-charcoal group-hover:text-gold transition-colors mb-3\">Keeping the ART in Art Deco — The Evolution of ICADS</h3><p class=\"text-charcoal/60 text-sm leading-relaxed mb-4\">Sharon Koskoff presents on the International Coalition of Art Deco Societies and the global preservation movement.</p><div class=\"space-y-2 text-sm text-charcoal/50\"><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock text-gold\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6l4 2\"></path></svg><span>3:00 PM</span></div><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin text-gold\" aria-hidden=\"true\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg><span>Cultural Council of Palm Beach County</span></div></div><a href=\"mailto:Art@ArtDecoPB.org?subject=RSVP: Keeping the ART in Art Deco — The Evolution of ICADS\" class=\"mt-6 inline-flex items-center gap-2 bg-charcoal text-cream px-6 py-2.5 rounded-full text-sm font-medium hover:bg-gold hover:text-charcoal transition-all duration-300 group-hover:translate-x-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calendar\" aria-hidden=\"true\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\"></rect><path d=\"M3 10h18\"></path></svg>RSVP Now</a></div></div><div class=\"group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 \" style=\"opacity:0;transform:translateY(30px)\"><div class=\"absolute top-4 left-4 z-10 bg-charcoal text-cream rounded-xl p-3 text-center min-w-[60px] shadow-lg\"><p class=\"text-gold text-xs font-bold uppercase tracking-wider\">Apr</p><p class=\"text-2xl font-display\">5</p></div><div class=\"h-2 bg-gradient-to-r from-gold via-copper to-gold\"></div><div class=\"p-6 pt-20\"><h3 class=\"font-display text-xl text-charcoal group-hover:text-gold transition-colors mb-3\">Walking Tour: Historic Downtown Lake Worth Beach</h3><p class=\"text-charcoal/60 text-sm leading-relaxed mb-4\">Explore the Art Deco gems of downtown Lake Worth Beach on a guided walking tour led by ADSPB President Sharon Koskoff.</p><div class=\"space-y-2 text-sm text-charcoal/50\"><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock text-gold\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6l4 2\"></path></svg><span>10:00 AM</span></div><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin text-gold\" aria-hidden=\"true\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg><span>Downtown Lake Worth Beach</span></div></div><a href=\"mailto:Art@ArtDecoPB.org?subject=RSVP: Walking Tour: Historic Downtown Lake Worth Beach\" class=\"mt-6 inline-flex items-center gap-2 bg-charcoal text-cream px-6 py-2.5 rounded-full text-sm font-medium hover:bg-gold hover:text-charcoal transition-all duration-300 group-hover:translate-x-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calendar\" aria-hidden=\"true\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\"></rect><path d=\"M3 10h18\"></path></svg>RSVP Now</a></div></div></div><div class=\"text-center mt-12\"><a class=\"inline-flex items-center gap-2 text-gold font-display tracking-wider uppercase text-sm hover:text-copper transition-colors\" href=\"/events\">View All Events<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div></section><section class=\"py-24 px-4 sm:px-6 lg:px-8 bg-charcoal relative overflow-hidden\"><div class=\"absolute inset-0 opacity-5\"><svg class=\"w-full h-full\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\"><defs><pattern id=\"grid\" width=\"10\" height=\"10\" patternUnits=\"userSpaceOnUse\"><path d=\"M 10 0 L 0 0 0 10\" fill=\"none\" stroke=\"#C8A951\" stroke-width=\"0.3\"></path></pattern></defs><rect width=\"100\" height=\"100\" fill=\"url(#grid)\"></rect></svg></div><div class=\"relative z-10 max-w-7xl mx-auto\"><div class=\"text-center mb-16\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex items-center justify-center gap-4 mb-6\"><div class=\"h-px w-16 bg-gold/40\"></div><div class=\"w-3 h-3 rotate-45 border border-gold/60\"></div><div class=\"h-px w-16 bg-gold/40\"></div></div><h2 class=\"font-display text-3xl sm:text-4xl lg:text-5xl tracking-wide text-cream\">Art Deco Elements</h2><p class=\"mt-4 text-lg max-w-2xl mx-auto text-cream/70\">Discover the distinctive architectural features that define Art Deco style in the Palm Beaches.</p></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"p-6 rounded-2xl border border-gold/10 bg-gold/5 hover:bg-gold/10 transition-colors group\"><div class=\"flex items-start gap-4\"><span class=\"text-gold/30 font-display text-4xl leading-none\">01</span><div><h3 class=\"font-display text-cream text-lg mb-2 group-hover:text-gold transition-colors\">Eyebrows</h3><p class=\"text-cream/50 text-sm leading-relaxed\">Cantilevered window shades included in the building&#x27;s structure. Eyebrows look like a &quot;shelf&quot; placed above a window. The...</p></div></div></div><div class=\"p-6 rounded-2xl border border-gold/10 bg-gold/5 hover:bg-gold/10 transition-colors group\"><div class=\"flex items-start gap-4\"><span class=\"text-gold/30 font-display text-4xl leading-none\">02</span><div><h3 class=\"font-display text-cream text-lg mb-2 group-hover:text-gold transition-colors\">Ziggurat or Stepped Pediment</h3><p class=\"text-cream/50 text-sm leading-relaxed\">Profiled like a staircase — up, down, up, down. Also known as &quot;zig zag&quot; or &quot;lightning bolt.&quot; Ziggurats are seen on the r...</p></div></div></div><div class=\"p-6 rounded-2xl border border-gold/10 bg-gold/5 hover:bg-gold/10 transition-colors group\"><div class=\"flex items-start gap-4\"><span class=\"text-gold/30 font-display text-4xl leading-none\">03</span><div><h3 class=\"font-display text-cream text-lg mb-2 group-hover:text-gold transition-colors\">Rounded Corners</h3><p class=\"text-cream/50 text-sm leading-relaxed\">Technology allowed for construction to be built with rounded corners. In the 1930s and 1940s, the design of airplanes, s...</p></div></div></div><div class=\"p-6 rounded-2xl border border-gold/10 bg-gold/5 hover:bg-gold/10 transition-colors group\"><div class=\"flex items-start gap-4\"><span class=\"text-gold/30 font-display text-4xl leading-none\">04</span><div><h3 class=\"font-display text-cream text-lg mb-2 group-hover:text-gold transition-colors\">Flat Roofs</h3><p class=\"text-cream/50 text-sm leading-relaxed\">Art Deco or Streamline buildings usually have a flat roof or multi-level flat roofs.</p></div></div></div><div class=\"p-6 rounded-2xl border border-gold/10 bg-gold/5 hover:bg-gold/10 transition-colors group\"><div class=\"flex items-start gap-4\"><span class=\"text-gold/30 font-display text-4xl leading-none\">05</span><div><h3 class=\"font-display text-cream text-lg mb-2 group-hover:text-gold transition-colors\">Threes</h3><p class=\"text-cream/50 text-sm leading-relaxed\">In Art Deco, everything seems to come in threes: three windows, three bandings, three eyebrows, or three steps. This is ...</p></div></div></div><div class=\"p-6 rounded-2xl border border-gold/10 bg-gold/5 hover:bg-gold/10 transition-colors group\"><div class=\"flex items-start gap-4\"><span class=\"text-gold/30 font-display text-4xl leading-none\">06</span><div><h3 class=\"font-display text-cream text-lg mb-2 group-hover:text-gold transition-colors\">Bandings or Racing Stripes</h3><p class=\"text-cream/50 text-sm leading-relaxed\">Horizontal bandings on the facades of buildings, which can be incised or applied in decorative materials such as tile. B...</p></div></div></div></div><div class=\"text-center mt-12\"><a class=\"inline-flex items-center gap-2 text-gold font-display tracking-wider uppercase text-sm hover:text-cream transition-colors\" href=\"/art-deco-elements\">Explore All Elements<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div></section><section class=\"py-24 px-4 sm:px-6 lg:px-8 bg-cream\"><div class=\"max-w-7xl mx-auto\"><div class=\"text-center mb-16\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex items-center justify-center gap-4 mb-6\"><div class=\"h-px w-16 bg-gold/30\"></div><div class=\"w-3 h-3 rotate-45 border border-gold/40\"></div><div class=\"h-px w-16 bg-gold/30\"></div></div><h2 class=\"font-display text-3xl sm:text-4xl lg:text-5xl tracking-wide text-charcoal\">Our Leadership</h2><p class=\"mt-4 text-lg max-w-2xl mx-auto text-charcoal/60\">Meet the dedicated team preserving Art Deco heritage in the Palm Beaches.</p></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto\"><div class=\"text-center p-8 rounded-2xl bg-white shadow-sm\"><div class=\"w-20 h-20 mx-auto mb-4 rounded-full overflow-hidden bg-gradient-to-br from-gold/20 to-copper/20 flex items-center justify-center\"><img alt=\"Sharon Koskoff\" loading=\"lazy\" width=\"80\" height=\"80\" decoding=\"async\" data-nimg=\"1\" class=\"w-full h-full object-cover\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Fsharon-koskoff-portrait.jpg&amp;w=96&amp;q=75 1x, /_next/image?url=%2Fimages%2Fsharon-koskoff-portrait.jpg&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Fsharon-koskoff-portrait.jpg&amp;w=256&amp;q=75\"/></div><h3 class=\"font-display text-lg text-charcoal\">Sharon Koskoff</h3><p class=\"text-gold text-sm mt-1\">President</p><p class=\"text-charcoal/60 text-sm mt-3 leading-relaxed\">Author of &quot;Art Deco of the Palm Beaches&quot; and cultural guardian dedicated to preserving Palm Beaches architecture. Sharon has led ADSPB since its founding and is recognized internationally for her preservation work.</p></div><div class=\"text-center p-8 rounded-2xl bg-white shadow-sm\"><div class=\"w-20 h-20 mx-auto mb-4 rounded-full overflow-hidden bg-gradient-to-br from-gold/20 to-copper/20 flex items-center justify-center\"><span class=\"font-display text-gold text-2xl\">ZZ</span></div><h3 class=\"font-display text-lg text-charcoal\">Zack Zacharias</h3><p class=\"text-gold text-sm mt-1\">Board Member</p><p class=\"text-charcoal/60 text-sm mt-3 leading-relaxed\">Active board member and advocate for Art Deco preservation in South Florida.</p></div><div class=\"text-center p-8 rounded-2xl bg-white shadow-sm\"><div class=\"w-20 h-20 mx-auto mb-4 rounded-full overflow-hidden bg-gradient-to-br from-gold/20 to-copper/20 flex items-center justify-center\"><span class=\"font-display text-gold text-2xl\">GL</span></div><h3 class=\"font-display text-lg text-charcoal\">Gary Lawrence</h3><p class=\"text-gold text-sm mt-1\">Music Education Coordinator</p><p class=\"text-charcoal/60 text-sm mt-3 leading-relaxed\">Brings the sounds of the Art Deco era to life through educational programs and events.</p></div></div></div></section><section class=\"py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-gold via-copper to-gold\"><div class=\"max-w-5xl mx-auto\"><div class=\"flex flex-col md:flex-row items-center gap-12\"><div class=\"flex gap-6 shrink-0\"><img alt=\"Art Deco of the Palm Beaches book\" loading=\"lazy\" width=\"140\" height=\"152\" decoding=\"async\" data-nimg=\"1\" class=\"rounded-xl shadow-lg\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Fbook-art-deco-palm-beaches.jpg&amp;w=256&amp;q=75 1x, /_next/image?url=%2Fimages%2Fbook-art-deco-palm-beaches.jpg&amp;w=384&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Fbook-art-deco-palm-beaches.jpg&amp;w=384&amp;q=75\"/><img alt=\"Murals of the Palm Beaches book\" loading=\"lazy\" width=\"126\" height=\"150\" decoding=\"async\" data-nimg=\"1\" class=\"rounded-xl shadow-lg hidden sm:block\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Fbook-murals-palm-beaches.jpg&amp;w=128&amp;q=75 1x, /_next/image?url=%2Fimages%2Fbook-murals-palm-beaches.jpg&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Fbook-murals-palm-beaches.jpg&amp;w=256&amp;q=75\"/></div><div class=\"text-center md:text-left\"><h2 class=\"font-display text-3xl text-charcoal mb-4\">Award-Winning Preservation</h2><p class=\"text-charcoal/70 max-w-2xl mb-8\">Winner of the Florida Book Awards Silver Medal (Visual Arts) and FAPA Silver Medal (Education).</p><div class=\"flex items-center justify-center md:justify-start gap-8 flex-wrap\"><div class=\"text-center\"><p class=\"font-display text-4xl text-charcoal\">39</p><p class=\"text-charcoal/60 text-sm\">Years</p></div><div class=\"w-px h-12 bg-charcoal/20 hidden sm:block\"></div><div class=\"text-center\"><p class=\"font-display text-4xl text-charcoal\">2</p><p class=\"text-charcoal/60 text-sm\">Silver Medals</p></div><div class=\"w-px h-12 bg-charcoal/20 hidden sm:block\"></div><div class=\"text-center\"><p class=\"font-display text-4xl text-charcoal\">501(c)3</p><p class=\"text-charcoal/60 text-sm\">Nonprofit</p></div></div></div></div></div></section><section class=\"py-24 px-4 sm:px-6 lg:px-8 bg-navy text-center relative overflow-hidden\"><div class=\"absolute inset-0\"><img alt=\"Art Deco building at night\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover opacity-20\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2Fmontgomery-building-night.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fmontgomery-building-night.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fmontgomery-building-night.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fmontgomery-building-night.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fmontgomery-building-night.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fmontgomery-building-night.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fmontgomery-building-night.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fmontgomery-building-night.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fmontgomery-building-night.jpg&amp;w=3840&amp;q=75\"/></div><div class=\"relative z-10 max-w-2xl mx-auto\"><h2 class=\"font-display text-3xl sm:text-4xl text-cream mb-4\">Join Our Mission</h2><p class=\"text-cream/60 mb-8\">Help us preserve the Art Deco architectural heritage of the Palm Beaches for future generations.</p><div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\"><a class=\"bg-gold text-charcoal px-8 py-4 rounded-full font-display tracking-wider uppercase text-sm hover:bg-cream transition-colors\" href=\"/membership\">Become a Member</a><a href=\"mailto:Art@ArtDecoPB.org\" class=\"border border-cream/30 text-cream px-8 py-4 rounded-full font-display tracking-wider uppercase text-sm hover:bg-cream/10 transition-colors\">Contact Us</a></div></div></section><!--$--><!--/$--></main><footer class=\"relative bg-charcoal text-cream overflow-hidden\"><div class=\"absolute inset-0 pointer-events-none opacity-5\"><svg class=\"w-full h-full\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><defs><pattern id=\"deco-fan\" x=\"0\" y=\"0\" width=\"20\" height=\"20\" patternUnits=\"userSpaceOnUse\"><path d=\"M10 20 Q10 10, 0 0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.3\" class=\"text-gold\"></path><path d=\"M10 20 Q10 10, 20 0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.3\" class=\"text-gold\"></path><path d=\"M10 20 Q10 10, 5 0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.2\" class=\"text-gold\"></path><path d=\"M10 20 Q10 10, 15 0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.2\" class=\"text-gold\"></path><path d=\"M10 20 Q10 10, 10 0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.2\" class=\"text-gold\"></path></pattern></defs><rect width=\"100\" height=\"100\" fill=\"url(#deco-fan)\"></rect></svg></div><div class=\"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16\"><div class=\"grid grid-cols-1 md:grid-cols-3 gap-12\"><div><div class=\"flex items-center gap-3 mb-4\"><img alt=\"ADSPB Logo\" loading=\"lazy\" width=\"40\" height=\"40\" decoding=\"async\" data-nimg=\"1\" class=\"rounded-full border-2 border-gold/30\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Flogo-adspb-small.jpg&amp;w=48&amp;q=75 1x, /_next/image?url=%2Fimages%2Flogo-adspb-small.jpg&amp;w=96&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Flogo-adspb-small.jpg&amp;w=96&amp;q=75\"/><div><p class=\"font-display text-cream text-sm tracking-widest uppercase\">ADSPB</p><p class=\"text-gold/60 text-xs\">Est. <!-- -->1987</p></div></div><p class=\"text-cream/60 text-sm leading-relaxed max-w-xs\">The Art Deco Society of the Palm Beaches promotes education, preservation and awareness of Twentieth Century Art, Architecture &amp; Design in the Palm Beaches.</p><div class=\"flex gap-4 mt-6\"><a href=\"https://www.youtube.com/channel/UC627yKy-KUfy58IJ2bQDpAg\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-cream/40 hover:text-gold transition-colors\" aria-label=\"YouTube\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-youtube\" aria-hidden=\"true\"><path d=\"M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17\"></path><path d=\"m10 15 5-3-5-3z\"></path></svg></a><a href=\"https://www.facebook.com/ArtDecoSocietyPalmBeaches\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-cream/40 hover:text-gold transition-colors\" aria-label=\"Facebook\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-facebook\" aria-hidden=\"true\"><path d=\"M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z\"></path></svg></a></div></div><div><h3 class=\"font-display text-gold tracking-widest uppercase text-sm mb-6\">Explore</h3><div class=\"space-y-3\"><a class=\"block text-cream/60 hover:text-gold transition-colors text-sm\" href=\"/events\">Upcoming Events</a><a class=\"block text-cream/60 hover:text-gold transition-colors text-sm\" href=\"/art-deco-elements\">Art Deco Elements</a><a class=\"block text-cream/60 hover:text-gold transition-colors text-sm\" href=\"/lectures\">L